# Backend configuration (NotaFácil Platform — feature 001)
# Copy to .env and adjust. Never commit real secrets (Princípio VI).

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=notafacil

# HTTP server
HTTP_ADDR=:8080

# Session JWT (HS256). Use a long random value in production.
JWT_SECRET=dev-insecure-change-me
# Session lifetime
SESSION_TTL=30m

# Invite link
INVITE_TTL=48h
# Base URL used to build the invite activation link sent by e-mail.
APP_BASE_URL=http://localhost:3000

# SMTP (transactional e-mail). In dev/CI a fake sender is used instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@notafacil.local
